# ============================================================================
# Connect this site to your thebestcrm workspace.
# Copy this file to .env.local and fill in the values.
# ============================================================================

# Your thebestcrm deployment URL (no trailing slash), e.g. https://thebestcrm.vercel.app
NEXT_PUBLIC_CRM_BASE_URL=

# The "Roofing Website Quote" form id (the value in /api/lead/<id>).
# From the seed: ripkl6t3cfo461l45o6a4e43
CRM_LEAD_FORM_ID=

# The chat widget slug (the value in /api/chat/<slug>/embed.js).
# From the seed: complete-roofing
NEXT_PUBLIC_CRM_CHAT_WIDGET_SLUG=
